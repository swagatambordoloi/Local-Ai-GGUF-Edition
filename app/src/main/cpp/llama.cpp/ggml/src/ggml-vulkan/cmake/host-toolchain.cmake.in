set(CMAKE_SYSTEM_NAME "@CMAKE_HOST_SYSTEM_NAME@")
set(CMAKE_BUILD_TYPE Release)
# Use _INIT to allow command line flags (like -static) to be preserved
set(CMAKE_C_FLAGS_INIT "-O2")
set(CMAKE_CXX_FLAGS_INIT "-O2")
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE NEVER)
set(CMAKE_C_COMPILER "@HOST_C_COMPILER@")
set(CMAKE_CXX_COMPILER "@HOST_CXX_COMPILER@")

# Normalize paths to use forward slashes (avoids escape sequence issues on Windows)
file(TO_CMAKE_PATH "${CMAKE_C_COMPILER}" CMAKE_C_COMPILER)
file(TO_CMAKE_PATH "${CMAKE_CXX_COMPILER}" CMAKE_CXX_COMPILER)
set(CMAKE_RUNTIME_OUTPUT_DIRECTORY @CMAKE_RUNTIME_OUTPUT_DIRECTORY@)

if("@CMAKE_C_COMPILER_ID@" STREQUAL "MSVC")
    foreach(CONFIG IN ITEMS DEBUG RELEASE MINSIZEREL RELWITHDEBINFO)
        set(CMAKE_RUNTIME_OUTPUT_DIRECTORY_${CONFIG} ${CMAKE_RUNTIME_OUTPUT_DIRECTORY})
    endforeach()
endif()
